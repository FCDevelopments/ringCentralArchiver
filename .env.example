# ============================================================
# RingCentral Archiver -> Box   |   copy to ".env" and fill in
# ============================================================

# ---------- RingCentral (JWT auth) ----------
# Create app at https://developers.ringcentral.com/my-account.html#/applications
#   App type: REST API App  |  Auth: JWT auth flow  |  No UI / Server-only
#   App scopes needed:  Read Call Log,  Read Call Recording
# Then create a JWT credential under your profile > Credentials,
# authorized for that app.
RC_CLIENT_ID=
RC_CLIENT_SECRET=
RC_JWT=
RC_SERVER_URL=https://platform.ringcentral.com

# ---------- Box (Client Credentials Grant) ----------
# Create app at https://app.box.com/developers/console
#   Custom App  ->  Server Authentication (Client Credentials Grant)
#   App Access Level: App + Enterprise Access
#   Then SUBMIT for authorization and approve it in the Box Admin Console
#   (Admin Console > Apps > Custom Apps Manager).
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_ENTERPRISE_ID=

# OPTIONAL, testing only: a developer token (Dev Console > Configuration >
# Generate Developer Token, valid 60 min). If set, it is used INSTEAD of the
# CCG credentials above, and uploads happen as your own Box user. Lets you
# test before the app is authorized in the Admin Console. Clear it when done.
BOX_DEV_TOKEN=

# The ONE destination folder. Open it in Box and copy the number from the URL:
#   https://app.box.com/folder/123456789012  ->  123456789012
# IMPORTANT: invite the app's service account email
# (looks like AutomationUser_xxxx@boxdevedition.com, shown in the
# Dev Console > General Settings) as an EDITOR collaborator on this folder,
# otherwise the app cannot see it.
BOX_FOLDER_ID=

# ---------- Behavior ----------
# monthly = one CSV per month ("Call Log - 2026-06.csv")  [recommended]
# never   = one single CSV forever ("Call Log - Master.csv")
CSV_ROTATION=monthly

# false = MP3s flat in the same folder as the CSV (truly one folder)
# true  = MP3s in a single "Recordings" subfolder (still no per-day sprawl)
RECORDINGS_SUBFOLDER=false

# Set false to archive the CSV only, no MP3s
DOWNLOAD_RECORDINGS=true

# Pause between recording downloads. RingCentral media endpoints allow only
# ~10 requests/minute ("Heavy" tier), so keep this at 6 or above.
MEDIA_THROTTLE_SECONDS=6.5
